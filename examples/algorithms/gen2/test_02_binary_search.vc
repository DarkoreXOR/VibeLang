// test_02: binary search + else-if + array indexing

internal func print(s: String);
internal func print_int(v: Int);
internal func int_array_len(a: [Int]): Int;

func binary_search(a: [Int], target: Int): Int {
    let n: Int = int_array_len(a);
    let t = (0, n);
    let (lo, hi) = t;

    while lo < hi {
        let mid: Int = lo + (hi - lo) / 2;

        if a[mid] < target {
            lo = mid + 1;
        } else if a[mid] > target {
            hi = mid;
        } else {
            return mid;
        }
    }

    return -1;
}

func main() {
    let a: [Int] = [1, 2, 3, 4, 5, 6, 7, 8, 9];

    print("search:");
    print_int(binary_search(a, 7));
    print_int(binary_search(a, 10));

    // negative indexing
    print_int(a[-1]);
}

